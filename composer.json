{
	"name": "drago-ex/translator",
	"type": "library",
	"description": "Lightweight translator for Nette Framework using NEON files, supporting global and module-specific translations.",
	"license": ["MIT"],
	"authors": [
		{
			"name": "Zdeněk Papučík",
			"homepage": "https://github.com/accgit"
		}
	],
	"require": {
		"php": ">=8.3 <9",
		"nette/di": "^3.1",
		"nette/utils": "^4.0",
		"nette/application": "^3.1",
		"nette/caching": "^3.4",
		"tracy/tracy": "^2.10"
	},
	"require-dev": {
		"nette/tester": "^2.5",
		"nette/bootstrap": "^3.1",
		"phpstan/phpstan-nette": "^2.0"
	},
	"extra": {
		"drago-tools": {
			"install": {
				"copy": {
					"src/Drago/assets/latte": "app/Core/Widget"
				}
			}
		}
	},
	"autoload": {
		"classmap": ["src/"]
	},
	"scripts": {
		"phpstan": "phpstan analyse",
		"tester": "tester tests -s"
	}
}
